{
  "hosting": {
    "target": "packoutsaz",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/hub/**",
        "destination": "/hub/index.html"
      }
    ],
    "headers": [
      {
        "source": "/hub/**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; font-src 'self'; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.run.app https://*.cloudfunctions.net wss://*.firebaseio.com https://api.openai.com; frame-src 'self' https://docs.google.com https://drive.google.com;"
          }
        ]
      },
      {
        "source": "/**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" }
        ]
      },
      {
        "source": "**/*.@(js|css|svg|webp|jpg|png|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
