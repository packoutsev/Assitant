---
import { site } from '../config/site';

export interface Props {
  message?: string;
}

const { message = "Have questions? We've helped hundreds of Arizona families through this exact situation." } = Astro.props;
---

<div class="bg-warm rounded-xl p-8 my-10 text-center">
  <p class="text-lg text-charcoal mb-4">{message}</p>
  <a
    href={site.phoneHref}
    class="inline-flex items-center gap-2 bg-navy text-white no-underline font-bold px-6 py-3 rounded-lg text-lg hover:bg-navy/90 transition-colors"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    Call {site.phone}
  </a>
  <p class="text-sm text-gray-500 mt-3">Available 24/7 &middot; Insurance-covered services</p>
</div>
